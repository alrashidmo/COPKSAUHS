# Firebase Environment Variables
# 
# Copy this file to .env.local and fill in your Firebase credentials
# DO NOT commit .env.local to version control!
# 
# To get these values:
# 1. Go to Firebase Console (console.firebase.google.com)
# 2. Select your project
# 3. Go to Project Settings (gear icon)
# 4. Scroll to "Your apps" section
# 5. Click on the Web app (</> icon)
# 6. Copy the firebaseConfig values below

# Firebase API Key - found in firebaseConfig.apiKey
FIREBASE_API_KEY=YOUR_API_KEY_HERE

# Firebase Auth Domain - found in firebaseConfig.authDomain
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase Database URL - found in firebaseConfig.databaseURL
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Firebase Project ID - found in firebaseConfig.projectId
FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket - found in firebaseConfig.storageBucket
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Messaging Sender ID - found in firebaseConfig.messagingSenderId
FIREBASE_MESSAGING_SENDER_ID=123456789000

# Firebase App ID - found in firebaseConfig.appId
FIREBASE_APP_ID=1:123456789000:web:abcdef1234567890

# Optional: Deployment Settings
NODE_ENV=production
DEPLOYMENT_URL=https://appe-hub.vercel.app

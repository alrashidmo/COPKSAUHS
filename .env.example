# Supabase Environment Variables
#
# Copy this file to .env.local and fill in your Supabase credentials
# DO NOT commit .env.local to version control!
#
# To get these values:
# 1. Go to https://supabase.com
# 2. Sign up (free - no credit card required!)
# 3. Create a new project
# 4. Go to Project Settings → API
# 5. Copy the Project URL and anon/public key below

# Supabase Project URL - found in Project Settings → API → URL
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=YOUR_SUPABASE_URL_HERE

# Supabase Anon Key - found in Project Settings → API → anon/public key
# This is a long string starting with "eyJ..."
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Optional: Deployment Settings
NODE_ENV=production
DEPLOYMENT_URL=https://copksauhs.vercel.app
